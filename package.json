{
  "name": "whatsapp-automation-system",
  "version": "1.0.0",
  "description": "Sistema de automação de respostas WhatsApp para loja",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "auth": "node server/index.js",
    "client": "npm --prefix client start",
    "install-all": "npm install; npm --prefix client install",
    "install-chrome": "npx puppeteer browsers install chrome",
    "postinstall": "echo Dependências instaladas com sucesso!"
  },
  "keywords": [
    "whatsapp",
    "automation",
    "chatbot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.0",
    "qrcode": "^1.5.4",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
